# Backend URL (WebSocket + API)
# Local development:
VITE_BACKEND_URL=http://localhost:3001
# Production (set in Vercel dashboard):
# VITE_BACKEND_URL=http://www.liarbar.duckdns.org:3001

# Voice chat TURN relay (optional but REQUIRED for reliable cross-network calls).
# STUN alone only works on the same LAN; without TURN, players on different
# networks / mobile data / symmetric NAT will fail to hear each other.
# VITE_TURN_URL=turn:turn.example.com:3478
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=

# Firebase config (optional - for Google Sign-In)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
